{
  "name": "Eigenpulse · 推送通知",
  "icon_glyph": "bell.badge.fill",
  "icon_tint": "rose",
  "description": "Post a platform message to /api/v1/notifications.",
  "endpoint": {
    "method": "POST",
    "url": "{EP_BASE}/api/v1/notifications",
    "scope_required": "notifications:write",
    "headers": {
      "Authorization": "Bearer {EP_TOKEN}",
      "Content-Type": "application/json"
    }
  },
  "config": {
    "EP_BASE": "http://192.168.1.50:3000",
    "EP_TOKEN": "ep_pat_REPLACE_ME"
  },
  "steps": [
    {
      "n": 1,
      "action": "Ask for Input",
      "bind": "Title",
      "input_type": "Text",
      "prompt": "标题"
    },
    {
      "n": 2,
      "action": "Ask for Input",
      "bind": "Body",
      "input_type": "Text",
      "prompt": "正文（可空）",
      "allow_multiline": true
    },
    {
      "n": 3,
      "action": "Choose from Menu",
      "bind": "Severity",
      "prompt": "严重度",
      "items": [
        {
          "label": "一般",
          "value": "info"
        },
        {
          "label": "警告",
          "value": "warn"
        },
        {
          "label": "严重",
          "value": "crit"
        }
      ]
    },
    {
      "n": 4,
      "action": "Dictionary",
      "bind": "Payload",
      "value": {
        "title": "{{Title}}",
        "body": "{{Body}}",
        "severity": "{{Severity}}",
        "source": "shortcuts"
      }
    },
    {
      "n": 5,
      "action": "Get Contents of URL",
      "bind": "Response",
      "method": "POST",
      "url": "{{EP_BASE}}/api/v1/notifications",
      "headers": {
        "Authorization": "Bearer {{EP_TOKEN}}",
        "Content-Type": "application/json"
      },
      "request_body": "{{Payload}}"
    },
    {
      "n": 6,
      "action": "Get Dictionary Value",
      "bind": "NotificationId",
      "from": "{{Response}}",
      "key": "id"
    },
    {
      "n": 7,
      "action": "Show Notification",
      "title": "已发送 · #{{NotificationId}}",
      "body": "{{Severity}} · {{Title}}"
    }
  ],
  "request_body_schema": {
    "title": "required string, at most 128 characters",
    "body": "optional string, at most 2000 characters",
    "severity": "info, warn, or crit; defaults to info",
    "source": "optional 2..32 lowercase letters, digits, or hyphens",
    "link": "optional safe in-app absolute path"
  },
  "response_shape": {
    "id": 42
  },
  "side_effects": [
    "Persists one platform notification and broadcasts it over SSE.",
    "Queues eligible SMTP, Bark, Telegram, and Discord deliveries in the durable outbox.",
    "Treats the optional link as display-only navigation."
  ]
}
